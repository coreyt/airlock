# Airlock environment variables
# Copy this file to .env and fill in your values.

# --- LLM Provider API Keys ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_AISTUDIO_API_KEY=AIza...
MISTRAL_API_KEY=...
PERPLEXITY_API_KEY=pplx-...

# --- Google Vertex AI (Gemini batch via /v1/batches) ---
# Required only for the gemini-*-vertex deployments in config.yaml. The
# AI Studio key above does NOT support the Batch API in LiteLLM; Vertex does.
VERTEX_PROJECT=my-gcp-project
VERTEX_LOCATION=us-central1
VERTEX_CREDENTIALS=/path/to/service-account.json
# ADC for the Batch/Files passthrough (/v1/files, /v1/batches). Completions use
# the per-deployment vertex_credentials above; the batch/files path resolves
# credentials via Application Default Credentials, so point ADC at the same key.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCS bucket LiteLLM stages batch input/output files in (Vertex batch only).
GCS_BUCKET_NAME=my-airlock-batch-bucket

# --- Local vLLM ---
VLLM_API_KEY=dummy-key

# --- Search / Research APIs ---
TAVILY_API_KEY=tvly-...
NEWS_CATCHER_API_KEY=...

# --- Airlock Proxy ---
AIRLOCK_MASTER_KEY=sk-airlock-change-me
AIRLOCK_HOST=0.0.0.0
AIRLOCK_PORT=4000

# --- Logging ---
# Where to write structured JSON logs (directory path)
AIRLOCK_LOG_DIR=./logs

# Comma-separated list of log record fields to redact (replace with [REDACTED]).
# Common fields: messages, response
# Example: AIRLOCK_LOG_REDACT_FIELDS=messages,response
# AIRLOCK_LOG_REDACT_FIELDS=

# Optional telemetry sinks (since 0.5.4 each is fed by the recorder and enabled by
# its own flag, not by a config.yaml callback entry):
# Optional: ship JSONL logs to S3 — needs the flag AND a bucket ([s3] extra)
# AIRLOCK_ENABLE_S3_LOGGER=1
# AIRLOCK_S3_BUCKET=my-company-llm-logs
# AWS_DEFAULT_REGION=us-east-1
# Optional: database logging — needs the flag AND a SQLAlchemy URL ([sql] extra)
# AIRLOCK_ENABLE_SQL_LOGGER=1
# AIRLOCK_SQL_URL=postgresql+psycopg://user:pass@host/airlock

# --- Guardrails ---
# Comma-separated list of blocked keywords/phrases (case-insensitive)
AIRLOCK_BLOCKED_KEYWORDS=Project Manhattan,Operation Bluebook,INTERNAL ONLY

# PII entity types to redact (comma-separated)
# See: https://microsoft.github.io/presidio/supported_entities/
AIRLOCK_PII_ENTITIES=CREDIT_CARD,US_SSN,EMAIL_ADDRESS,PHONE_NUMBER,US_BANK_NUMBER,IBAN_CODE

# PII hydration: restore redacted values in tool-call arguments on the
# response path.  Set to 'off' to disable (placeholders stay as-is).
# AIRLOCK_PII_HYDRATION=tools

# --- Adaptive Guardrails ---
# Controls adaptive enforcer behaviour: observe (default), shadow, enforce
AIRLOCK_ENFORCE_MODE=observe

# --- Dynamic Processing (Fast subsystem) ---
# Model failover map — JSON mapping model name → ordered fallback list.
# As of 0.5.1 the map is DERIVED from config.yaml `router_settings.fallbacks` (no separate
# hardcoded default), and candidates are filtered against your `model_list` (unknown/typo'd
# targets are skipped). This env var overrides the config-derived map; its targets must also
# resolve to real model_list aliases.
# AIRLOCK_FAILOVER_MAP={"claude-sonnet":["claude-haiku","claude-opus"],"claude-opus":["claude-sonnet","gemini-3.1-pro"]}

# --- Intelligent Routing ---
# Cost tier model sets — JSON mapping tier name → model alias list
# AIRLOCK_COST_TIERS={"low":["claude-haiku","gemini-flash","gemini-flash-lite","gpt-4o-mini","mistral-small"],"medium":["claude-sonnet","gemini-pro","gpt-4o","mistral-large","codestral"],"high":["claude-opus","gemini-3-pro","gemini-3.1-pro","magistral-medium"]}

# Session affinity TTL in seconds (default 3600 = 1 hour).
# 0.5.1: also settable in config.yaml as `airlock_settings.session_ttl` (env wins).
# AIRLOCK_SESSION_TTL=3600

# Provider daily budgets for Airlock's budget-aware routing (USD). These are EXAMPLES, not
# defaults — 0.5.1 removed the hidden hardcoded defaults. With no budget configured (here or in
# config.yaml `router_settings.provider_budget_config`), there is NO proactive swap and NO warn.
# A value of 0 means unlimited / no enforcement. Env overrides the config block.
# AIRLOCK_PROVIDER_BUDGETS={"anthropic":50.0,"openai":50.0,"gemini":25.0,"mistral":25.0}

# Near-budget warn ratio — the SINGLE threshold (0.0-1.0, default 0.8) at which the monitor
# warns (X-Airlock-Budget-State: near_limit) AND the router proactively swaps providers.
# 0.5.1: unified (was monitor 0.8 / router 0.9). Also settable as `airlock_settings.budget_warn_ratio`.
# AIRLOCK_BUDGET_WARN_RATIO=0.8

# Provider-spend checkpoint interval in seconds (default 60). Spend is checkpointed to
# `spend_state.json` in AIRLOCK_STATE_DIR and restored on restart (0.5.1) — see operations docs.
# AIRLOCK_SPEND_CHECKPOINT_INTERVAL=60

# Smart model complexity thresholds — [simple_max, complex_min] (scores 0-1)
# Prompts scoring < simple_max → low tier, ≥ complex_min → high tier, between → medium.
# 0.5.1: also settable in config.yaml as `airlock_settings.smart_thresholds` (env wins).
# AIRLOCK_SMART_THRESHOLDS=[0.30, 0.60]

# --- Response Scanner ---
# Mode: observe (log only, default) or enforce (block suspicious responses)
AIRLOCK_RESPONSE_SCAN_MODE=observe
# Composite score threshold for blocking (0.0-1.0, default 0.5)
# AIRLOCK_RESPONSE_SCAN_THRESHOLD=0.5

# --- MCP Tool Access Control ---
# Comma-separated tool allowlist (empty = allow all configured tools)
# AIRLOCK_MCP_ALLOWED_TOOLS=read_file,search,query_db
# Comma-separated tool blocklist (takes precedence when both set)
# AIRLOCK_MCP_BLOCKED_TOOLS=execute_command,delete_file

# --- MCP stdio command allowlist (LiteLLM) ---
# LiteLLM only launches stdio MCP servers whose command BASENAME is allow-listed
# (built-in: deno,docker,node,npx,python,python3,uvx). A venv `.../bin/python`
# passes; a custom launcher binary does not and 403s at tool discovery. Add extra
# basenames here (comma-separated). See docs/guide/mcp-servers.md.
# LITELLM_MCP_STDIO_EXTRA_COMMANDS=ado-mcp,my-tool
