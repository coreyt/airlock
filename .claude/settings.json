{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git restore:*)",
      "Bash(git checkout --:*)",
      "Bash(git stash:*)",
      "Bash(git worktree list)",
      "Bash(git worktree prune)",
      "Bash(git -C:*)",
      "Bash(uv run:*)",
      "Bash(uv sync:*)",
      "Bash(uv venv:*)",
      "Bash(uv pip:*)",
      "Bash(./scripts/preflight.sh:*)",
      "Bash(./scripts/agent-permission-canary.sh:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(realpath:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(df:*)",
      "Bash(du:*)",
      "Bash(date:*)",
      "Bash(echo:*)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(sudo:*)",
      "Bash(apt:*)",
      "Bash(apt-get:*)",
      "Bash(systemctl:*)",
      "Bash(kill:*)",
      "Bash(pkill:*)",
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git worktree add:*)",
      "Bash(git worktree remove:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git -C * push:*)",
      "Bash(git -C * reset --hard:*)",
      "Bash(git -C * clean:*)",
      "Bash(git -C * merge:*)",
      "Bash(git -C * rebase:*)",
      "Bash(git -C * cherry-pick:*)",
      "Bash(git -C * worktree add:*)",
      "Bash(git -C * worktree remove:*)"
    ]
  },
  "mcpServers": {
    "wake": {
      "command": "wake-mcp"
    }
  }
}
