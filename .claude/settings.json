{
  "attribution": {
    "commit": ""
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git restore:*)",
      "Bash(git checkout --:*)",
      "Bash(git stash:*)",
      "Bash(git worktree list)",
      "Bash(git worktree prune)",
      "Bash(git -C:*)",
      "Bash(uv run:*)",
      "Bash(uv sync:*)",
      "Bash(uv venv:*)",
      "Bash(uv pip:*)",
      "Bash(./scripts/preflight.sh:*)",
      "Bash(./scripts/agent-permission-canary.sh:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(realpath:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(df:*)",
      "Bash(du:*)",
      "Bash(date:*)",
      "Bash(echo:*)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(wget:*)",
      "Bash(sudo:*)",
      "Bash(apt:*)",
      "Bash(apt-get:*)",
      "Bash(kill:*)",
      "Bash(pkill:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git -C * push:*)",
      "Bash(git -C * reset --hard:*)",
      "Bash(git -C * clean:*)",
      "Bash(git -C * cherry-pick:*)"
    ],
    "ask": [
      "Bash(git rebase:*)",
      "Bash(git -C * merge:*)",
      "Bash(git -C * rebase:*)",
      "Bash(git -C * worktree add:*)",
      "Bash(git -C * worktree remove:*)"
    ]
  },
  "hooks": {
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "export WAKE_STORE=\"$CLAUDE_PROJECT_DIR/.wake/events.db\" WAKE_OUTPUT_DIR=\"$CLAUDE_PROJECT_DIR\"; wake claude-postcompact"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "export WAKE_STORE=\"$CLAUDE_PROJECT_DIR/.wake/events.db\" WAKE_OUTPUT_DIR=\"$CLAUDE_PROJECT_DIR\"; wake bridge-send"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "export WAKE_STORE=\"$CLAUDE_PROJECT_DIR/.wake/events.db\" WAKE_OUTPUT_DIR=\"$CLAUDE_PROJECT_DIR\"; wake read-context"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "export WAKE_STORE=\"$CLAUDE_PROJECT_DIR/.wake/events.db\" WAKE_OUTPUT_DIR=\"$CLAUDE_PROJECT_DIR\"; wake claude-posttool"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/ensure-spacy-after-sync.sh",
            "if": "Bash(uv sync*)"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "export WAKE_STORE=\"$CLAUDE_PROJECT_DIR/.wake/events.db\" WAKE_OUTPUT_DIR=\"$CLAUDE_PROJECT_DIR\"; wake claude-precompact"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "export WAKE_STORE=\"$CLAUDE_PROJECT_DIR/.wake/events.db\" WAKE_OUTPUT_DIR=\"$CLAUDE_PROJECT_DIR\"; wake plan-check"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "export WAKE_STORE=\"$CLAUDE_PROJECT_DIR/.wake/events.db\" WAKE_OUTPUT_DIR=\"$CLAUDE_PROJECT_DIR\"; wake guard-check"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "export WAKE_STORE=\"$CLAUDE_PROJECT_DIR/.wake/events.db\" WAKE_OUTPUT_DIR=\"$CLAUDE_PROJECT_DIR\"; wake guard-check"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "export WAKE_STORE=\"$CLAUDE_PROJECT_DIR/.wake/events.db\" WAKE_OUTPUT_DIR=\"$CLAUDE_PROJECT_DIR\"; wake guard-check"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/git-commit-check.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "export WAKE_STORE=\"$CLAUDE_PROJECT_DIR/.wake/events.db\" WAKE_OUTPUT_DIR=\"$CLAUDE_PROJECT_DIR\"; wake session-start && (wake bridge start >/dev/null 2>&1 </dev/null &) && wake render-projection && cat .wake/projection.md"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "export WAKE_STORE=\"$CLAUDE_PROJECT_DIR/.wake/events.db\" WAKE_OUTPUT_DIR=\"$CLAUDE_PROJECT_DIR\"; wake claude-stop"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "export WAKE_STORE=\"$CLAUDE_PROJECT_DIR/.wake/events.db\" WAKE_OUTPUT_DIR=\"$CLAUDE_PROJECT_DIR\"; wake bridge stop ; wake session-end && wake extract-smart-events && wake snapshot && wake render-projection && wake render-wake-dir"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-stop.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "export WAKE_STORE=\"$CLAUDE_PROJECT_DIR/.wake/events.db\" WAKE_OUTPUT_DIR=\"$CLAUDE_PROJECT_DIR\"; wake reintegrate-hook"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "export WAKE_STORE=\"$CLAUDE_PROJECT_DIR/.wake/events.db\" WAKE_OUTPUT_DIR=\"$CLAUDE_PROJECT_DIR\"; wake claude-prompt-whisper"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "wake": {
      "command": "wake-mcp"
    }
  }
}
